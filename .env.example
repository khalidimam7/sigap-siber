# Copy file ini ke `.env.local`, lalu isi nilainya untuk development lokal.
# Jangan isi token asli di file ini karena file ini boleh masuk repository.

# URL aplikasi saat development / demo
NODE_ENV=development
APP_URL=http://localhost:5174
PORT=3001
HOST=127.0.0.1

# Supabase PostgreSQL / production database
# Ambil dari Supabase Project Settings > Database > Connection string.
# Jika direct connection IPv6 tidak bisa dijangkau dari jaringan lokal, gunakan Supabase pooler/IPv4 connection string.
# Jika password mengandung karakter spesial, URL-encode password dulu.
# @=%40, #=%23, /=%2F, ?=%3F, &=%26, :=%3A
DATABASE_URL=postgresql://postgres:replace_with_password@replace_with_host:5432/postgres
DATABASE_SSL=true

# Telegram Bot API untuk notifikasi internal petugas/admin
# Buat bot via @BotFather, lalu masukkan bot ke grup petugas.
TELEGRAM_NOTIFICATIONS_ENABLED=true
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=replace_with_admin_group_chat_id
TELEGRAM_FALLBACK_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML

# Secret backend. Ganti dengan random string panjang di production.
APP_SECRET=replace_with_random_secret
JWT_SECRET=replace_with_random_secret

# Seed akun Petugas/Admin awal.
# Dipakai oleh: npm run auth:create-admin
ADMIN_NAME=Petugas Sigap Siber
ADMIN_EMAIL=admin@bireuenkab.go.id
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password
